@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Iniciar Sesión</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <style>
        body {
            min-height: 100vh;
            margin: 0;
            background: linear-gradient(135deg, #240046, #3c096c, #4361ee, #00b4d8);
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: Arial, sans-serif;
        }

        .main-box {
            width: 1250px;
            min-height: 760px;
            display: flex;
            background: white;
            border-radius: 28px;
            overflow: hidden;
            box-shadow: 0 25px 60px rgba(0,0,0,.35);
        }

        .left-panel {
            width: 48%;
            background: linear-gradient(160deg, #4cc9f0, #4361ee, #7209b7);
            color: white;
            padding: 45px 35px;
            position: relative;
            overflow: hidden;
        }

            .left-panel::before {
                content: "";
                position: absolute;
                width: 240px;
                height: 240px;
                border-radius: 50%;
                background: rgba(255,255,255,.18);
                bottom: -80px;
                left: -80px;
            }

            .left-panel::after {
                content: "";
                position: absolute;
                width: 170px;
                height: 170px;
                border-radius: 50%;
                background: rgba(255,255,255,.13);
                top: 70px;
                right: -70px;
            }

        .logo {
            font-weight: bold;
            font-size: 22px;
            position: relative;
            z-index: 2;
        }

        .welcome {
            margin-top: 120px;
            position: relative;
            z-index: 2;
        }

            .welcome h1 {
                font-size: 52px;
                font-weight: bold;
            }

            .welcome p {
                font-size: 20px;
                opacity: .95;
                line-height: 1.7;
            }

        .credit-icon {
            font-size: 120px;
            margin-top: 45px;
        }

        .right-panel {
            width: 52%;
            padding: 95px 80px;
            background: linear-gradient(135deg, #e0e7ff, #c7d2fe, #f3e8ff);
        }

            .right-panel h2 {
                color: #4c1d95;
                font-size: 42px;
                font-weight: bold;
                margin-bottom: 12px;
            }

        .subtitle {
            color: #64748b;
            margin-bottom: 35px;
            font-size: 18px;
        }

        .form-control {
            height: 60px;
            border: none;
            background: #eef2f7;
            border-radius: 12px;
            font-size: 18px;
            padding-left: 18px;
        }

            .form-control:focus {
                box-shadow: 0 0 0 2px rgba(67, 97, 238, .25);
                background: #fff;
            }

        .btn-login {
            background: linear-gradient(135deg, #4361ee, #7209b7);
            border: none;
            color: white;
            font-weight: bold;
            height: 62px;
            border-radius: 18px;
            font-size: 20px;
        }

            .btn-login:hover {
                opacity: .9;
                color: white;
            }

        .register-link {
            text-align: center;
            font-size: 18px;
            margin-top: 12px;
            font-weight: 500;
        }

            .register-link a {
                color: #4f46e5;
                font-weight: bold;
                text-decoration: none;
            }

                .register-link a:hover {
                    text-decoration: underline;
                }

        @@media (max-width: 900px) {
            .main-box {
                width: 95%;
                flex-direction: column;
            }

            .left-panel, .right-panel {
                width: 100%;
            }

            .welcome {
                margin-top: 40px;
            }
        }
    </style>
</head>

<body>
    <div class="main-box">

        <div class="left-panel">
            <div class="logo">💳 CréditoPlus</div>

            <div class="welcome">
                <h1>Bienvenido</h1>
                <p>
                    Ingresa con tu DNI para gestionar tus solicitudes de crédito
                    de forma rápida y segura.
                </p>

                <div class="credit-icon">💰</div>
            </div>
        </div>

        <div class="right-panel">
            <h2>Iniciar Sesión</h2>
            <p class="subtitle">Accede a tu cuenta de créditos</p>

            <form asp-controller="Login" asp-action="IniciarSeccion" method="post">

                <input class="form-control mb-3" type="text" placeholder="DNI" required name="dni"
                       maxlength="8"
                       oninput="this.value=this.value.replace(/[^0-9]/g,'')" />

                <input class="form-control mb-3" type="password" placeholder="Contraseña" required name="clave" />

                <div class="d-grid gap-2 mb-3">
                    <button class="btn btn-login" type="submit">Iniciar Sesión</button>
                </div>

                @if (ViewData["Mensaje"] != null)
                {
                    <div class="alert alert-danger" role="alert">
                        @ViewData["Mensaje"]
                    </div>
                }
                @if (TempData["Mensaje"] != null)
                {
                    <div class="alert alert-success">
                        @TempData["Mensaje"]
                    </div>
                }

                <div class="register-link mb-2">
                    <a href="@Url.Action("OlvideContrasena", "Login")">¿Olvidaste tu contraseña?</a>
                </div>

                <div class="register-link">
                    ¿No tienes una cuenta?
                    <a href="@Url.Action("Registro", "Login")">Regístrate</a>
                </div>

            </form>
        </div>
    </div>
</body>
</html>