@{
    Layout = null;

    string nombre = User.Identity.Name ?? "Cliente";
    string apellido = User.FindFirst("Apellido")?.Value ?? "";
    string dni = User.FindFirst("Dni")?.Value ?? "Sin registro";
    string celular = User.FindFirst("Celular")?.Value ?? "Sin registro";
    string correo = User.FindFirst("Correo")?.Value ?? "Sin registro";
    string nombreCompleto = nombre + " " + apellido;
}
<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>CrediPlus - Panel Principal</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">


    <style>
        body {
            margin: 0;
            font-family: Arial, sans-serif;
            background: #faf8ff;
            color: #1f1235;
        }

        .layout {
            display: flex;
            min-height: 100vh;
        }

        .sidebar {
            width: 300px;
            background: linear-gradient(180deg, #240046, #3c096c, #5a189a);
            color: white;
            padding: 28px 22px;
            display: flex;
            flex-direction: column;
        }

        .content {
            flex: 1;
            padding: 34px 42px;
        }

        .logo {
            font-size: 22px;
            font-weight: bold;
            margin-bottom: 45px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .menu a {
            display: block;
            color: white;
            text-decoration: none;
            padding: 18px 22px;
            border-radius: 16px;
            margin-bottom: 22px;
            font-size: 18px;
            font-weight: 500;
        }

            .menu a:hover,
            .menu .active {
                background: rgba(255,255,255,.18);
            }

        .faq {
            background: rgba(255,255,255,.12);
            padding: 28px;
            border-radius: 22px;
            margin-top: auto;
            margin-bottom: 15px;
        }

        .top {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 30px;
        }

        .welcome-text {
            color: #4c1d95;
            font-size: 18px;
        }

        .top h1 {
            font-size: 38px;
            font-weight: 800;
            margin: 5px 0;
        }

        .top p {
            font-size: 17px;
            color: #51446b;
        }

        .profile-card {
            background: white;
            padding: 20px 30px;
            border-radius: 18px;
            box-shadow: 0 8px 25px rgba(0,0,0,.08);
            display: flex;
            align-items: center;
            gap: 16px;
            min-width: 280px;
        }

        .avatar {
            width: 58px;
            height: 58px;
            border-radius: 50%;
            background: linear-gradient(135deg, #6d28d9, #9333ea);
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 32px;
            box-shadow: 0 5px 15px rgba(109,40,217,.35);
        }

        .profile-card h4 {
            margin: 0;
            font-weight: bold;
        }

        .profile-card span {
            color: #4c1d95;
            font-size: 14px;
        }

        .cards {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 22px;
            margin-top: 25px;
        }

        .card-box {
            background: white;
            border-radius: 22px;
            padding: 25px;
            display: flex;
            gap: 18px;
            align-items: flex-start;
            border: 2px solid #ece5ff;
            box-shadow: 0 10px 25px rgba(124,58,237,.12);
            transition: .3s;
        }

            .card-box:hover {
                transform: translateY(-4px);
                border-color: #7c3aed;
                box-shadow: 0 14px 30px rgba(124,58,237,.20);
            }

            .card-box h3 {
                font-size: 18px;
                margin: 0;
                color: #27104e;
            }

            .card-box h2 {
                margin: 10px 0 5px;
                color: #7c3aed;
                font-size: 34px;
                font-weight: 800;
            }

            .card-box span {
                color: #777;
            }

        .icon {
            width: 60px;
            height: 60px;
            border-radius: 18px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 24px;
        }

        .purple {
            background: linear-gradient(135deg,#7c3aed,#9333ea);
        }

        .blue {
            background: linear-gradient(135deg,#2563eb,#3b82f6);
        }

        .green {
            background: linear-gradient(135deg,#16a34a,#22c55e);
        }

        .orange {
            background: linear-gradient(135deg,#ea580c,#fb923c);
        }

        .loan-banner {
            margin-top: 35px;
            background: linear-gradient(90deg,#240046,#5a189a,#7209b7);
            border-radius: 28px;
            padding: 60px 65px;
            color: white;
            display: flex;
            justify-content: space-between;
            align-items: center;
            box-shadow: 0 15px 40px rgba(76,29,149,.25);
        }

        .loan-left {
            display: flex;
            align-items: center;
            gap: 35px;
        }

        .loan-image {
            width: 220px;
            height: 220px;
            border-radius: 34px;
            background: rgba(255,255,255,.12);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 115px;
        }

        .loan-info h2 {
            font-size: 48px;
            margin-bottom: 12px;
            font-weight: 800;
        }

        .loan-info p {
            color: #ddd6fe;
            margin-bottom: 30px;
            font-size: 20px;
        }

        .loan-feature {
            display: flex;
            align-items: center;
            gap: 15px;
            margin-bottom: 18px;
        }

            .loan-feature i {
                width: 55px;
                height: 55px;
                border-radius: 16px;
                background: rgba(255,255,255,.12);
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 22px;
            }

            .loan-feature strong {
                display: block;
                font-size: 18px;
            }

            .loan-feature span {
                color: #ddd6fe;
                font-size: 16px;
            }

        .loan-right {
            width: 650px;
            margin-right: 220px;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

            .loan-right small {
                color: #ddd6fe;
                font-size: 15px;
            }

            .loan-right h1 {
                font-size: 68px;
                margin: 12px 0 18px;
                font-weight: 800;
                line-height: 1.1;
            }

        .loan-line {
            width: 100%;
            height: 2px;
            background: rgba(255,255,255,.2);
            margin: 25px 0 35px;
        }

        .loan-btn {
            width: 100%;
            border: none;
            border-radius: 20px;
            padding: 26px 35px;
            background: #22c55e;
            color: white;
            font-size: 28px;
            font-weight: bold;
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 20px;
            transition: .3s;
            margin-top: 35px;
        }

            .loan-btn:hover {
                background: #16a34a;
            }

        .bottom-cards {
            margin-top: 35px;
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 32px;
            align-items: stretch;
        }

        .info-card {
            background: white;
            border-radius: 24px;
            padding: 30px;
            box-shadow: 0 10px 30px rgba(0,0,0,.08);
            min-height: 340px;
        }

            .info-card h3 {
                font-size: 30px;
                font-weight: bold;
                color: #3c096c;
                margin-bottom: 28px;
            }

        .info-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 25px;
            padding: 18px 0;
            border-bottom: 1px solid #ececec;
            font-size: 19px;
        }

            .info-item:last-child {
                border-bottom: none;
            }

            .info-item span {
                color: #4b5563;
                font-weight: 500;
            }

            .info-item strong {
                color: #111827;
            }

        .status-purple {
            color: #7c3aed;
            font-weight: bold;
        }

        .bottom-cards {
            margin-top: 35px;
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 28px;
        }

        .finance-card,
        .benefits-card {
            background: white;
            border-radius: 24px;
            padding: 30px;
            box-shadow: 0 10px 30px rgba(0,0,0,.08);
            min-height: 340px;
        }

            .finance-card h3,
            .benefits-card h3 {
                font-size: 38px;
                font-weight: 800;
                color: #3c096c;
                margin-bottom: 35px;
            }

        .finance-item {
            display: flex;
            justify-content: space-between;
            padding: 12px 0;
            border-bottom: 1px solid #ececec;
            font-size: 17px;
        }

        .finance-box {
            margin-top: 18px;
            padding: 16px 18px;
            border-radius: 14px;
            display: flex;
            justify-content: space-between;
            font-size: 17px;
            font-weight: bold;
        }

        .purple-box {
            background: #f3e8ff;
            color: #7c3aed;
        }

        .green-box {
            background: #dcfce7;
            color: #16a34a;
        }

        .benefit-item {
            margin-bottom: 22px;
        }

            .benefit-item strong {
                display: block;
                color: #3c096c;
                font-size: 24px;
                font-weight: 700;
                margin-bottom: 6px;
            }

            .benefit-item p {
                margin: 4px 0 0;
                color: #6b7280;
                font-size: 18px;
                line-height: 1.5;
            }

        .loan-features {
            margin-top: 35px;
            width: 100%;
            background: white;
            border-radius: 24px;
            padding: 40px 50px;
            display: grid;
            grid-template-columns: repeat(5, 1fr);
            align-items: center;
            gap: 35px;
            box-shadow: 0 10px 30px rgba(124,58,237,.08);
        }

        .feature-box {
            display: flex;
            align-items: center;
            gap: 18px;
            width: 100%;
        }

            .feature-box i {
                font-size: 38px;
                color: #7c3aed;
            }

            .feature-box h4 {
                font-size: 26px;
                font-weight: 800;
                line-height: 1.2;
                margin-bottom: 6px;
            }

            .feature-box p {
                margin: 0;
                font-size: 18px;
                line-height: 1.4;
                color: #6b7280;
            }
    </style>
</head>

<body>
    <div class="layout">

        <div class="sidebar">
            <div class="logo">
                💳 CrediPlus
            </div>

            <div class="menu">
                <a class="active" href="#">🏠 Inicio</a>
                <a href="#">📄 Mis Solicitudes</a>
                <a href="#">▦ Simulador de Crédito</a>
                <a href="#">👤 Perfil Personal</a>
                <a href="#">⚙ Configuración</a>
                <a href="@Url.Action("IniciarSeccion", "Login")">↪ Cerrar Sesión</a>
            </div>

            <div class="faq">
                <h5>❔ Preguntas frecuentes</h5>
                <p>Resolvemos tus dudas</p>
            </div>
        </div>

        <div class="content">
            <div class="top">


                <div>
                    <strong class="welcome-text">¡Bienvenido de vuelta!</strong>
                    <h1>Listo para solicitar el monto de tu préstamo</h1>
                    <p>Gestiona tu crédito personal de forma 100% online, rápida y segura.</p>
                </div>

                <div class="profile-card">
                    <div class="avatar">
                        <i class="fas fa-user"></i>
                    </div>
                    <div>
                        <h4>@nombreCompleto</h4>
                        <span>Cliente registrado</span>
                    </div>
                </div>
            </div>
            <div class="cards">
                <div class="card-box">
                    <div class="icon purple">
                        <i class="fas fa-shield-alt"></i>
                    </div>
                    <div>
                        <h3>Nivel de Confianza</h3>
                        <h2>Sin registro</h2>
                        <span>-</span>
                    </div>
                </div>

                <div class="card-box">
                    <div class="icon blue">
                        <i class="fas fa-wallet"></i>
                    </div>
                    <div>
                        <h3>Capacidad de Pago</h3>
                        <h2>Sin registro</h2>
                        <span>-</span>
                    </div>
                </div>

                <div class="card-box">
                    <div class="icon green">
                        <i class="fas fa-dollar-sign"></i>
                    </div>
                    <div>
                        <h3>Límite Máximo</h3>
                        <h2>Sin registro</h2>
                        <span>-</span>
                    </div>
                </div>

                <div class="card-box">
                    <div class="icon orange">
                        <i class="fas fa-chart-line"></i>
                    </div>
                    <div>
                        <h3>Deuda Actual</h3>
                        <h2>Sin registro</h2>
                        <span>-</span>
                    </div>
                </div>
            </div>
            <div class="loan-banner">

                <div class="loan-left">

                    <div class="loan-image">
                        💸
                    </div>

                    <div class="loan-info">
                        <h2>Solicita tu préstamo personal</h2>

                        <p>
                            Obtén hasta S/ 50,000 de forma rápida,
                            100% online y segura.
                        </p>

                        <div class="loan-feature">
                            <i class="fas fa-bolt"></i>
                            <div>
                                <strong>Aprobación inmediata</strong>
                                <span>Respuesta en minutos</span>
                            </div>
                        </div>

                        <div class="loan-feature">
                            <i class="fas fa-file-alt"></i>
                            <div>
                                <strong>Sin papeles</strong>
                                <span>Todo el proceso es digital</span>
                            </div>
                        </div>

                        <div class="loan-feature">
                            <i class="fas fa-calendar-alt"></i>
                            <div>
                                <strong>Plazos flexibles</strong>
                                <span>12, 24, 36, 48, 60 y 72 meses</span>
                            </div>
                        </div>

                    </div>
                </div>

                <div class="loan-right">

                    <small>Monto máximo a solicitar</small>

                    <h1>S/ 50,000</h1>

                    <div class="loan-line"></div>

                    <button class="loan-btn">
                        Solicitar préstamo
                        <i class="fas fa-arrow-right"></i>
                    </button>

                </div>

            </div>
            <div class="bottom-cards">

                <div class="info-card">
                    <h3>Información de tu perfil</h3>

                    <div class="info-item">
                        <span>👤 Nombre completo</span>
                        <strong>@nombreCompleto</strong>
                    </div>

                    <div class="info-item">
                        <span>🪪 DNI</span>
                        <strong>@dni</strong>
                    </div>

                    <div class="info-item">
                        <span>📱 Celular</span>
                        <strong>@celular</strong>
                    </div>

                    <div class="info-item">
                        <span>✉ Correo electrónico</span>
                        <strong>@correo</strong>
                    </div>

                    <div class="info-item">
                        <span>📅 Fecha de registro</span>
                        <strong>20/05/2024</strong>
                    </div>

                    <div class="info-item">
                        <span>🛡 Estado de verificación</span>
                        <strong class="status-purple">Sin registro</strong>
                    </div>
                </div>
                <div class="finance-card">
                    <h3>Resumen financiero</h3>

                    <div class="finance-item">
                        <span>💸 Ingresos mensuales</span>
                        <strong>Sin registro</strong>
                    </div>

                    <div class="finance-item">
                        <span>📉 Egresos mensuales</span>
                        <strong>Sin registro</strong>
                    </div>

                    <div class="finance-item">
                        <span>🏦 Otros créditos</span>
                        <strong>Sin registro</strong>
                    </div>

                    <div class="finance-box purple-box">
                        <span>Capacidad de endeudamiento (30%)</span>
                        <strong>Sin registro</strong>
                    </div>

                    <div class="finance-box green-box">
                        <span>Disponible para préstamo</span>
                        <strong>Sin registro</strong>
                    </div>
                </div>
                <div class="benefits-card">
                    <h3>¿Por qué elegir CrediPlus?</h3>

                    <div class="benefit-item">
                        <div>
                            <strong>📈 Las mejores tasas del mercado</strong>
                            <p>Tasas competitivas y transparentes</p>
                        </div>
                    </div>

                    <div class="benefit-item">
                        <div>
                            <strong>🛡 Seguridad garantizada</strong>
                            <p>Protegemos tu información 24/7</p>
                        </div>
                    </div>

                    <div class="benefit-item">
                        <div>
                            <strong>👨‍💼 Atención personalizada</strong>
                            <p>Asesores disponibles para ti</p>
                        </div>
                    </div>

                    <div class="benefit-item">
                        <div>
                            <strong>📋 Sin costos ocultos</strong>
                            <p>Sin comisiones adicionales</p>
                        </div>
                    </div>
                </div>
                
            </div>
            <div class="loan-features">

                <div class="feature-box">
                    <i class="fas fa-laptop"></i>
                    <div>
                        <h4>100% online</h4>
                        <p>Todo el proceso es digital</p>
                    </div>
                </div>

                <div class="feature-box">
                    <i class="fas fa-money-check-alt"></i>
                    <div>
                        <h4>Hasta S/ 50,000</h4>
                        <p>Monto máximo a prestar</p>
                    </div>
                </div>

                <div class="feature-box">
                    <i class="fas fa-calendar-alt"></i>
                    <div>
                        <h4>Hasta 72 meses</h4>
                        <p>Plazos flexibles disponibles</p>
                    </div>
                </div>

                <div class="feature-box">
                    <i class="fas fa-check-circle"></i>
                    <div>
                        <h4>Aprobación rápida</h4>
                        <p>Respuesta en minutos</p>
                    </div>
                </div>

                <div class="feature-box">
                    <i class="fas fa-shield-alt"></i>
                    <div>
                        <h4>Pagos seguros</h4>
                        <p>Plataforma segura y confiable</p>
                    </div>
                </div>

            </div>
        </div>
    </div>
</body>
</html>